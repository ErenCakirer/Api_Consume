@model List<ResultLastBookingsDto>

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Son Rezervasyonlar</h4>
                <div class="active-member">
                    <div class="table-responsive">
                        <table class="table table-xs mb-0">
                            <thead>
                                <tr>
                                    <th>Müşteri</th>
                                    <th>Aktivite</th>
                                    <th>Durum</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                           
                                            @item.Name <br />
                                           
                                        </td>

                                        <td>@item.Status</td>

                                        @if (item.Status == "Onaylandı")
                                        {
                                            <td>
                                                <div class="progress" style="height: 6px">
                                                    <div class="progress-bar bg-success" style="width: 100%"></div>
                                                </div>
                                            </td>
                                            <td><i class="fa fa-circle text-success mr-2"></i> Onaylandı</td>
                                        }
                                        else if (item.Status == "Onay Bekliyor")
                                        {
                                            <td>
                                                <div class="progress" style="height: 6px">
                                                    <div class="progress-bar bg-warning" style="width: 50%"></div>
                                                </div>
                                            </td>
                                            <td><i class="fa fa-circle text-warning mr-2"></i> Onay Bekliyor</td>
                                        }
                                        else if (item.Status == "İptal Edildi")
                                        {
                                            <td>
                                                <div class="progress" style="height: 6px">
                                                    <div class="progress-bar bg-danger" style="width: 100%"></div>
                                                </div>
                                            </td>
                                            <td><i class="fa fa-circle text-danger mr-2"></i> İptal Edildi</td>
                                        }
                                        else
                                        {
                                            <td>
                                                <div class="progress" style="height: 6px">
                                                    <div class="progress-bar bg-secondary" style="width: 100%"></div>
                                                </div>
                                            </td>
                                            <td><i class="fa fa-circle text-secondary mr-2"></i> Belirsiz</td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>