@using HotelProjectEntity.Concrete
@model List<HotelProjectEntity.Concrete.AppUser>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/AdminLayout.cshtml";
}

<table class="table table-xs mb-0">
    <thead>
        <tr>
            <th>#</th>
            <th>Ad-Soyad</th>
            <th>Şehir</th>
            <th>Ülke</th>
            <th>Durum</th>
        
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><img src="@item.ImageUrl" class="rounded-circle mr-3" style="width:40px; height:40px; object-fit:cover;" alt=""></td>
                <td>@item.Name @item.Surname</td>
                <td>@item.City</td>
                <td>@item.Country</td>
                <td><i class="fa fa-circle text-success mr-2"></i> Aktif</td>

               
            </tr>
        }
    </tbody>
</table>
<br />
<a href="/Register/Index" class="btn btn-primary">Yeni Kullanıcı Kayıt</a>