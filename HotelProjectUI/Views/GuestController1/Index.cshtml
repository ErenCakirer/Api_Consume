    @model List<GuestResultDto>

    @{
        ViewData["Title"] = "Index";
        Layout = "~/Views/AdminLayout/AdminLayout.cshtml";
    }



    <div class="container-fluid pt-4 px-4">
        <div class="bg-white text-center rounded p-4">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h5 class="mb-0">Oda Listesi</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-bordered table-hover text-start align-middle mb-0">
                    <thead>
                        <tr class="text-dark">
                            <th scope="col">#</th>
                            <th scope="col">Ad</th>
                            <th scope="col">Soyad</th>
                            <th scope="col">Şehir</th>
                            <th scope="col">Sil</th>
                            <th scope="col">Güncelle</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                       
                                <td class="text-center">@item.GuestID</td>

                                <td>@item.Name</td>

                      
                                <td>@item.Surname</td>
                                <td>@item.City</td>
                        
                                <td class="text-center">
                                    <a href="/Guest/DeleteGuest/@item.GuestID"
                                       class="btn btn-danger btn-sm">
                                        Sil
                                    </a>
                                </td>

                                <td class="text-center">
                                    <a href="/Guest/UpdateGuest/@item.GuestID"
                                       class="btn btn-success btn-sm">
                                        Güncelle
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="text-start mt-3">
                <a href="/Guest/AddGuest" class="btn btn-primary">Yeni Misafir Ekle</a>
            </div>
        </div>
    </div>