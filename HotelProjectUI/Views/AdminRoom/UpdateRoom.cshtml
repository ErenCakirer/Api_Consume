@model UpdateRoomDto
@{
    ViewData["Title"] = "UpdateRoom";
    Layout = "~/Views/AdminLayout/AdminLayout.cshtml";
}
<form asp-controller="Room" asp-action="UpdateRoom" method="post">
    <input type="hidden" asp-for="RoomID" />
    <label>Oda No</label>
    <input type="text" asp-for="RoomNumber" class="form-control" />
    <br />
    <label>Başlık</label>
    <input type="text" asp-for="Title" class="form-control" />
    <br />
    <label>Fiyat</label>
    <input type="text" asp-for="Price" class="form-control" />
    <br />
    <label>Yatak Sayısı</label>
    <input type="text" asp-for="BedCount" class="form-control" />
    <br />
    <label>Banyo Sayısı</label>
    <input type="text" asp-for="BathCount" class="form-control" />
    <br />
    <label>Açıklama</label>
    <input type="text" asp-for="Description" class="form-control" />
    <br />
    <button type="submit" class="btn btn-primary">Odayı Ekle</button>
</form>
