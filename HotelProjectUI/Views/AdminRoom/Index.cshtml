@model List<ResultRoomDto>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/AdminLayout.cshtml";
}

<div class="container-fluid pt-4 px-4">
    <div class="bg-white text-center rounded p-4">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h5 class="mb-0">Oda Listesi</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-bordered table-hover text-start align-middle mb-0">
                <thead>
                    <tr class="text-dark">
                        <th scope="col">#</th>
                        <th scope="col">Oda No / Başlık</th>
                        <th scope="col">Açıklama</th>
                        <th scope="col">Sil</th>
                        <th scope="col">Güncelle</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                       
                            <td class="text-center">@item.RoomID</td>

                            <td>@item.Title</td>

                      
                            <td>@item.Description</td>

                        
                            <td class="text-center">
                                <a href="/AdminRoom/DeleteRoom/@item.RoomID"
                                   class="btn btn-danger btn-sm">
                                    Sil
                                </a>
                            </td>

                            <td class="text-center">
                                <a href="/AdminRoom/UpdateRoom/@item.RoomID"
                                   class="btn btn-success btn-sm">
                                    Güncelle
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="text-start mt-3">
            <a href="/AdminRoom/AddRoom" class="btn btn-primary">Yeni Oda Ekle</a>
        </div>
    </div>
</div>