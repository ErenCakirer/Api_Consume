@model RapidApi.Models.BookingHotelViewModel.Result[]
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Parametreli Otel Arama</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
</head>
<body class="container mt-5">

    <div class="card shadow col-md-8 mx-auto mb-4">
        <div class="card-body">
            <h5 class="card-title text-center text-success">Booking Şehir Koduna (ID) Göre Otel Arama</h5>

            <form method="get" action="/SearchLocationID/Index" class="form-inline justify-content-center mt-3">
                <input type="text" name="destId" class="form-control mr-2 col-md-7" placeholder="Şehir ID girin... (Örn: Berlin için -1746443, Amsterdam için -553173)" value="@ViewBag.CurrentDestId" required />
                <button type="submit" class="btn btn-success">Otelleri Getir</button>
            </form>
        </div>
    </div>

    @if (Model != null && Model.Length > 0)
    {
        <div class="card shadow col-md-10 mx-auto">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">ID: @ViewBag.CurrentDestId İçin Bulunan Oteller</h5>
            </div>
            <div class="card-body">
                <table class="table table-bordered table-striped table-hover">
                    <thead class="thead-dark text-center">
                        <tr>
                            <th>#</th>
                            <th>Otel Görseli</th>
                            <th>Otel Adı</th>
                            <th>Puan</th>
                            <th>Para Birimi</th>
                            <th>Toplam Fiyat</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int count = 0;
                        }
                        @foreach (var hotel in Model)
                        {
                            count++;
                            <tr>
                                <td class="text-center font-weight-bold">@count</td>
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(hotel.photoMainUrl))
                                    {
                                        <img src="@hotel.photoMainUrl" alt="Otel Resmi" class="img-thumbnail" style="width: 100px; height: 70px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">Görsel Yok</span>
                                    }
                                </td>
                                <td class="font-weight-bold">@hotel.name</td>
                                <td class="text-center">
                                    <span class="badge badge-warning text-dark font-weight-bold">
                                        ⭐ @hotel.reviewScore
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="badge badge-info">@hotel.currency</span>
                                </td>
                                <td class="text-success font-weight-bold text-center">
                                    @if (hotel.priceBreakdown?.grossPrice != null)
                                    {
                                        @hotel.priceBreakdown.grossPrice.value.ToString("N2")
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning col-md-8 mx-auto text-center">Bu ID değerine ait otel bulunamadı.</div>
    }

</body>
</html>